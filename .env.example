# Django runtime
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# SMTP email (set USE_SMTP_EMAIL=true to enable real delivery)
USE_SMTP_EMAIL=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@saminelflame.com

# Google OAuth (set both values to show Google login button)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
